---
import type { Category } from "../data/site";
import { getProductsByCategory } from "../data/products";
import ProductCard from "./ProductCard.astro";

interface Props {
  id: Category;
  title: string;
}

const { id, title } = Astro.props;
const products = getProductsByCategory(id);
---

<section id={id} class="py-16 sm:py-20 px-4" aria-labelledby={`heading-${id}`}>
  <div class="max-w-6xl mx-auto">
    <!-- Section heading with GTA-style underline -->
    <div class="mb-10 reveal" style="--stagger: 0">
      <h2
        id={`heading-${id}`}
        class="font-display text-3xl sm:text-4xl md:text-5xl text-text"
      >
        {title}
      </h2>
      <div class="mt-3 h-1 w-24 bg-gradient-to-r from-vyra to-sa-orange rounded-sm" aria-hidden="true"></div>
    </div>

    <!-- Product grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-6">
      {products.map((product, i) => (
        <ProductCard product={product} index={i + 1} />
      ))}
    </div>
  </div>
</section>
