---
import { siteConfig } from "../data/site";

const icons: Record<string, string> = {
  cookie: `<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1" /></svg>`,
  glass: `<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
  bottle: `<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 2h4v3l1.5 2.5a4 4 0 01.5 2V20a2 2 0 01-2 2h-4a2 2 0 01-2-2V9.5a4 4 0 01.5-2L10 5V2zm-1 11h6" /></svg>`,
  leaf: `<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>`,
  flame: `<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 2s4 4.5 4 9a4 4 0 01-8 0c0-1.5.5-2.5 1-3.5C10 10 12 10 12 12m0 10a6 6 0 006-6c0-3.5-3-7-6-10-3 3-6 6.5-6 10a6 6 0 006 6z" /></svg>`,
};
---

<nav
  id="catalogue"
  class="sticky top-0 z-40 bg-bg/95 backdrop-blur-sm border-b border-surface-border safe-top"
  aria-label="Catégories de produits"
>
  <div class="relative max-w-6xl mx-auto">
    <div
      class="flex gap-2 sm:gap-1 overflow-x-auto px-4 py-3 scrollbar-none snap-nav safe-x"
      data-category-scroll
    >
      {siteConfig.categories.map((cat) => (
        <a
          href={`#${cat.id}`}
          data-nav-link
          class="touch-cta flex items-center gap-2 whitespace-nowrap px-4 py-2 rounded-sm
                 text-sm font-medium text-text-muted
                 hover:text-text hover:bg-surface-elevated
                 aria-[current=true]:text-vyra aria-[current=true]:bg-vyra-dim
                 transition-colors duration-150 min-h-[44px]"
        >
          <span set:html={icons[cat.icon]} />
          {cat.label}
        </a>
      ))}
    </div>

    <!-- Scroll hint : gradient + chevron orange animé, disparaît quand on atteint la fin -->
    <div
      class="nav-scroll-hint pointer-events-none absolute right-0 top-0 bottom-0 flex items-center justify-end
             pr-2 pl-10 bg-gradient-to-l from-bg via-bg/80 to-transparent
             transition-opacity duration-200 md:hidden"
      data-scroll-hint
      aria-hidden="true"
    >
      <svg class="nav-hint-chevron w-5 h-5 text-sa-orange drop-shadow-[0_0_6px_rgba(232,147,90,0.6)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </div>
  </div>
</nav>

<script>
  const scroll = document.querySelector<HTMLElement>("[data-category-scroll]");
  const hint = document.querySelector<HTMLElement>("[data-scroll-hint]");
  if (scroll && hint) {
    const update = () => {
      const atEnd = scroll.scrollLeft + scroll.clientWidth >= scroll.scrollWidth - 8;
      hint.style.opacity = atEnd ? "0" : "1";
    };
    update();
    scroll.addEventListener("scroll", update, { passive: true });
    window.addEventListener("resize", update);
  }
</script>
