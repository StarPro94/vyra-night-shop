---
import { siteConfig } from "../data/site";

const marquee = [...siteConfig.marqueeMessages, ...siteConfig.marqueeMessages];

// Deterministic particle seeds (no hydration mismatch)
const particles = Array.from({ length: 24 }, (_, i) => ({
  left: (i * 37) % 100,
  delay: (i * 0.7) % 12,
  duration: 22 + ((i * 3) % 18),
  drift: (i % 2 === 0 ? 1 : -1) * (8 + ((i * 5) % 30)),
  color: ["text-sa-orange", "text-vyra", "text-sa-violet-light", "text-sa-mauve"][i % 4],
}));
---

<section
  class="hero-night-canvas relative min-h-dvh overflow-hidden pb-40 lg:pb-48 flex flex-col justify-center"
  aria-labelledby="hero-title"
>
  <!-- ═══════════════════════════════════════════════
       LAYER 0 — Atmosphere: particles + light shafts
       ═══════════════════════════════════════════════ -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    {particles.map((p) => (
      <span
        class={`particle ${p.color}`}
        style={`left: ${p.left}%; top: 100%; --p-delay: ${p.delay}; --p-dur: ${p.duration}s; --p-x: ${p.drift}px;`}
      />
    ))}
    <div class="absolute -top-1/3 -left-1/4 w-1/2 h-[140%] opacity-[0.06] rotate-12 bg-gradient-to-b from-sa-orange via-transparent to-transparent blur-3xl"></div>
    <div class="absolute -top-1/3 -right-1/4 w-1/2 h-[140%] opacity-[0.07] -rotate-12 bg-gradient-to-b from-sa-violet via-transparent to-transparent blur-3xl"></div>
  </div>

  <!-- ═══════════════════════════════════════════════
       LAYER 4 — Bat-Signal: cone from skyline chases V across the sky
       Two synchronized animations (same duration, same keyframes)
       ═══════════════════════════════════════════════ -->
  <div class="hidden md:block absolute inset-0 overflow-hidden pointer-events-none z-0" aria-hidden="true">
    <!-- Cone rotates from skyline apex to follow V (angle set dynamically by script below) -->
    <div class="batsignal-cone absolute inset-0">
      <svg
        class="absolute inset-0 w-full h-full"
        preserveAspectRatio="none"
        viewBox="0 0 100 100"
        style="overflow: visible;"
      >
        <defs>
          <!-- Faisceau : lumineux \u00e0 la skyline, reste visible jusqu'au V o\u00f9 il
               se fond dans le halo (le JS scale la pointe pile sur le V). -->
          <linearGradient id="bs-beam" x1="50%" y1="100%" x2="50%" y2="0%">
            <stop offset="0%" stop-color="#81C784" stop-opacity="0.55"/>
            <stop offset="20%" stop-color="#66BB6A" stop-opacity="0.38"/>
            <stop offset="50%" stop-color="#66BB6A" stop-opacity="0.24"/>
            <stop offset="80%" stop-color="#66BB6A" stop-opacity="0.14"/>
            <stop offset="100%" stop-color="#66BB6A" stop-opacity="0.06"/>
          </linearGradient>
          <filter id="bs-blur" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur stdDeviation="1.6"/>
          </filter>
        </defs>
        <!-- Apex (50,100) = bas du viewport (skyline). Tip (46,-150)/(54,-150)
             sort largement au-dessus du viewport pour toujours atteindre le V,
             quelle que soit sa position ou l'aspect ratio. -->
        <polygon
          points="50,100 46,-150 54,-150"
          fill="url(#bs-beam)"
          filter="url(#bs-blur)"
        />
      </svg>
    </div>

    <!-- V + halo wandering unit. Cone rotation is locked on V center via raf script.
         Dimensions volontairement contenues : le bat-signal est atmosph\u00e9rique,
         pas focal. Il compl\u00e8te VYRA sans lui voler la vedette. -->
    <div class="batsignal-wander absolute top-0 left-0">
      <!-- Soft radial halo -->
      <div
        class="absolute"
        style="top: 50%; left: 50%; transform: translate(-50%, -50%); width: 14vw; height: 12vw; background: radial-gradient(ellipse, rgba(129,199,132,0.18) 0%, rgba(102,187,106,0.06) 45%, rgba(102,187,106,0) 75%); filter: blur(24px);"
      ></div>
      <!-- Batman-style ring (subtle, discrete) -->
      <div
        class="absolute pointer-events-none"
        style="top: 50%; left: 50%; transform: translate(-50%, -50%); width: clamp(3.5rem, 7vw, 6rem); aspect-ratio: 1; border-radius: 9999px; border: 1.25px solid rgba(129, 199, 132, 0.24); box-shadow: 0 0 12px rgba(129, 199, 132, 0.10), inset 0 0 10px rgba(129, 199, 132, 0.05); opacity: 0.55;"
        aria-hidden="true"
      ></div>
      <span
        class="block font-display leading-none select-none text-vyra"
        style="font-size: clamp(2.5rem, 5vw, 4.5rem); opacity: 0.24; filter: blur(0.8px);"
      >
        V
      </span>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════
       MAIN GRID — Editorial split (desktop) / stack (mobile)
       ═══════════════════════════════════════════════ -->
  <div class="relative z-10 max-w-7xl mx-auto px-5 sm:px-8 pt-14 lg:pt-20">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-y-10 lg:gap-x-10 items-start">

      <!-- ┌─────────────────────────────────────────┐
           │ LEFT COLUMN — Logo block (60%)           │
           └─────────────────────────────────────────┘ -->
      <div class="lg:col-span-7 relative text-center lg:text-left">
        <!-- Serial number header -->
        <p
          class="hero-rise font-mono text-[10px] sm:text-xs tracking-[0.22em] text-text-subtle mb-5 uppercase lg:max-w-fit lg:pr-4"
          style="--rise-delay: 100"
        >
          <span class="text-sa-orange">★</span>
          14 RUE LEVEILLÉ · V-C 02600 · DEPUIS 2026
          <span class="text-sa-orange">★</span>
        </p>

        <!-- VYRA wordmark (monumental, left-aligned on desktop) -->
        <h1
          id="hero-title"
          class="hero-rise font-display vyra-wordmark text-text leading-[0.82]"
          style="font-size: clamp(5rem, 18vw, 16rem); --rise-delay: 250"
        >
          VYRA
        </h1>

        <!-- NIGHT SHOP (neon glow) — aligned with VYRA baseline -->
        <p
          class="hero-rise mt-1 lg:mt-2"
          style="--rise-delay: 700"
        >
          <span
            class="font-display-alt text-vyra tracking-[0.18em] neon-glow inline-block"
            style="font-size: clamp(1.25rem, 3.4vw, 3rem);"
          >
            NIGHT SHOP
          </span>
        </p>

        <!-- Loading bar — now BELOW the whole logo block (below the R's descender) -->
        <div
          class="loading-bar hero-rise mt-8 lg:mt-10 mx-auto lg:mx-0 w-4/5 max-w-md lg:w-full lg:max-w-xl"
          style="--rise-delay: 900"
          aria-hidden="true"
        ></div>

        <!-- Floating stickers around logo (desktop only) -->
        <div class="hidden lg:block" aria-hidden="true">
          <span class="sticker sticker-1 absolute top-2 right-4 xl:right-8">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0v10l-8 4m8-14l-8 4m0 0v10m0-10L4 7m0 0v10l8 4" />
            </svg>
            Snacks
          </span>
          <span class="sticker sticker-2 absolute top-[52%] -left-2 xl:-left-6">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
            </svg>
            CBD & Puff
          </span>
        </div>
      </div>

      <!-- ┌─────────────────────────────────────────┐
           │ RIGHT COLUMN — Info block (40%)          │
           └─────────────────────────────────────────┘ -->
      <div class="lg:col-span-5 relative text-center lg:text-left lg:pt-4 xl:pt-6">
        <!-- Status LIVE callout -->
        <div
          id="live-status"
          class="hero-rise inline-flex items-center gap-3 px-4 py-2 mb-6 lg:mb-8
                 bg-black/60 backdrop-blur-sm border border-white/10 rounded-full
                 text-xs sm:text-sm font-mono tracking-wider uppercase"
          style="--rise-delay: 0"
          aria-live="polite"
          aria-atomic="true"
        >
          <span class="status-dot text-neon-live" aria-hidden="true"></span>
          <span id="live-status-text" class="text-text">Vérification des horaires...</span>
        </div>

        <!-- Editorial categories list (factual, magazine-style) -->
        <ul
          class="hero-rise font-display leading-[1] tracking-tight space-y-1"
          style="font-size: clamp(2rem, 4.2vw, 3.5rem); --rise-delay: 500"
          aria-label="Nos rayons"
        >
          <li class="text-sa-orange">Snacks.</li>
          <li class="text-vyra">Boissons.</li>
          <li class="text-sa-mauve">Puff &amp; CBD.</li>
          <li class="text-sa-violet-light">Imports US/JP.</li>
        </ul>

        <!-- Description body -->
        <p class="hero-rise text-text-muted text-sm sm:text-base mt-6 max-w-md mx-auto lg:mx-0 leading-relaxed" style="--rise-delay: 1000">
          Épicerie de nuit à {siteConfig.address.city} — ouverte de {siteConfig.hours.open} à {siteConfig.hours.close}, 7j/7.
        </p>

        <!-- CTA duo (stacked on lg — narrow column, editorial menu feel) -->
        <div
          class="hero-rise mt-7 flex flex-col sm:flex-row lg:flex-col items-center sm:items-stretch lg:items-stretch justify-center lg:justify-start gap-3 sm:gap-4 lg:gap-3 lg:max-w-sm lg:mx-0 mx-auto"
          style="--rise-delay: 1100"
        >
          <a
            href={`https://wa.me/${siteConfig.whatsapp}`}
