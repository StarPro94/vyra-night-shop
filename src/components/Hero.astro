          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
            Commander WhatsApp
          </a>
          <a
            href="#catalogue"
            class="inline-flex items-center justify-center gap-2 px-7 py-3 min-h-[48px] w-full sm:w-auto
                   bg-transparent border-2 border-sa-orange text-sa-orange font-bold text-sm uppercase tracking-wider rounded-sm
                   hover:bg-sa-orange hover:text-bg hover:-translate-y-0.5 active:scale-[0.98]
                   transition-all duration-150"
          >
            Voir le catalogue
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </a>
        </div>

        <!-- Floating stickers on info side (desktop only) -->
        <div class="hidden lg:block" aria-hidden="true">
          <span class="sticker sticker-3 absolute -top-2 -right-2 xl:-right-6">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Import US/JP
          </span>
          <span class="sticker sticker-4 absolute bottom-4 -right-4 xl:-right-8">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0" />
            </svg>
            Livraison
          </span>
        </div>
      </div>
    </div>

    <!-- Mobile stickers row (stacked under both columns) -->
    <div class="lg:hidden mt-10 flex flex-wrap justify-center gap-2 hero-rise" style="--rise-delay: 1200" aria-hidden="true">
      <span class="sticker sticker-1" style="animation: none; transform: rotate(-4deg);">Snacks</span>
      <span class="sticker sticker-2" style="animation: none; transform: rotate(3deg);">CBD & Puff</span>
      <span class="sticker sticker-3" style="animation: none; transform: rotate(-2deg);">Import US/JP</span>
      <span class="sticker sticker-4" style="animation: none; transform: rotate(5deg);">Livraison</span>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════
       LAYER 1 — Skyline silhouette (bottom)
       ═══════════════════════════════════════════════ -->
  <div class="absolute bottom-10 sm:bottom-12 inset-x-0 h-28 sm:h-36 pointer-events-none z-10" aria-hidden="true">
    <div class="absolute inset-x-0 bottom-0 h-full bg-gradient-to-t from-black via-black/80 to-transparent"></div>
    <svg
