  <!-- ═══════════════════════════════════════════════
       LAYER 7 — Marquee ticker (bottom band)
       ═══════════════════════════════════════════════ -->
  <div
    class="absolute bottom-0 inset-x-0 z-10 bg-sa-orange text-bg border-y-2 border-black py-2.5 overflow-hidden"
    aria-hidden="true"
  >
    <div class="marquee">
      <div class="marquee__track">
        {marquee.map((msg) => (
          <span class="marquee__item">
            <span aria-hidden="true">✦</span>
            {msg}
          </span>
        ))}
      </div>
      <div class="marquee__track" aria-hidden="true">
        {marquee.map((msg) => (
          <span class="marquee__item">
            <span aria-hidden="true">✦</span>
            {msg}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  // ═════════════════════════════════════════════════
  // LIVE STATUS — reads real time, computes open/closed
  // ═════════════════════════════════════════════════
  (function () {
    const statusEl = document.getElementById("live-status");
    const textEl = document.getElementById("live-status-text");
    if (!statusEl || !textEl) return;

    const openHour = 18;
    const closeHour = 2;

    function compute() {
      const now = new Date();
      const h = now.getHours();
      const m = now.getMinutes();
      const minutesNow = h * 60 + m;
      const openMin = openHour * 60;
      const closeMin = closeHour * 60;

      const afterOpen = minutesNow >= openMin;
      const beforeClose = minutesNow < closeMin;
      const isOpen = afterOpen || beforeClose;

      const dot = statusEl!.querySelector(".status-dot");

      if (isOpen) {
        let rem: number;
        if (afterOpen) {
          rem = 24 * 60 - minutesNow + closeMin;
        } else {
          rem = closeMin - minutesNow;
        }
        const rh = Math.floor(rem / 60);
        const rm = rem % 60;
        const hPart = rh > 0 ? `${rh}h` : "";
        const mPart = rm > 0 ? `${String(rm).padStart(2, "0")}min` : rh > 0 ? "" : "0min";
        const sep = rh > 0 && rm > 0 ? " " : "";
        textEl!.innerHTML = `<span class="text-neon-live font-bold">Ouvert</span> · Ferme dans ${hPart}${sep}${mPart}`;
        statusEl!.setAttribute("aria-label", `Statut en direct : ouvert. Ferme dans ${hPart} ${mPart}`);
        if (dot) {
          dot.classList.remove("is-closed");
          (dot as HTMLElement).classList.add("text-neon-live");
          (dot as HTMLElement).classList.remove("text-neon-dead");
        }
      } else {
        const rem = minutesNow < openMin ? openMin - minutesNow : 24 * 60 - minutesNow + openMin;
        const rh = Math.floor(rem / 60);
        const rm = rem % 60;
        textEl!.innerHTML = `<span class="text-neon-dead font-bold">Fermé</span> · Ouvre à 18h00 (dans ${rh}h${String(rm).padStart(2, "0")})`;
        statusEl!.setAttribute("aria-label", `Statut en direct : fermé. Ouvre dans ${rh} heures ${rm} minutes`);
        if (dot) {
          dot.classList.add("is-closed");
          (dot as HTMLElement).classList.remove("text-neon-live");
          (dot as HTMLElement).classList.add("text-neon-dead");
        }
      }
    }

    compute();
    const interval = setInterval(compute, 30_000);
    window.addEventListener("beforeunload", () => clearInterval(interval), { once: true });
  })();

  // ═════════════════════════════════════════════════
  // BAT-SIGNAL — cone rotation locked on V center (pixel-perfect)
  // Reads V position after CSS transform and computes exact angle
  // from skyline apex (50vw, 100vh) to V center each frame.
  // ═════════════════════════════════════════════════
  (function () {
    const wander = document.querySelector<HTMLElement>(".batsignal-wander");
    const cone = document.querySelector<HTMLElement>(".batsignal-cone");
    if (!wander || !cone) return;

    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    if (reduceMotion.matches) return;

    // Polygone SVG : apex (50,100) → tip (_, -150). Sur SVG stretch\u00e9 en 100vh,
    // la longueur naturelle du faisceau avant scale est 250% = 2.5 \u00d7 innerHeight.
    const NATURAL_LEN_VH_FACTOR = 2.5;

    let rafId = 0;
    const tick = () => {
      const r = wander.getBoundingClientRect();
      const vx = r.left + r.width / 2;
      const vy = r.top + r.height / 2;
      const apexX = window.innerWidth * 0.5;
      const apexY = window.innerHeight; // skyline = bas du viewport
      const dx = vx - apexX;
      const dy = apexY - vy;
      const distance = Math.sqrt(dx * dx + dy * dy);
      const naturalLen = NATURAL_LEN_VH_FACTOR * window.innerHeight;
      // scaleY ajuste la longueur du faisceau pour qu'il s'arr\u00eate pile au V.
      // Le multiplicateur 1.05 laisse le V juste \u00e0 l'int\u00e9rieur de la pointe.
      const scaleY = (distance * 1.05) / naturalLen;
      const angleDeg = (Math.atan2(dx, dy) * 180) / Math.PI;
      cone.style.transform = `rotate(${angleDeg}deg) scaleY(${scaleY})`;
      rafId = requestAnimationFrame(tick);
    };
    rafId = requestAnimationFrame(tick);

    window.addEventListener(
      "beforeunload",
      () => cancelAnimationFrame(rafId),
      { once: true }
    );
  })();
</script>
