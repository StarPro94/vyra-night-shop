---
import { siteConfig } from "../data/site";
---

<section class="hero-bg relative flex flex-col items-center justify-center min-h-dvh px-4 text-center overflow-hidden">
  <!-- Decorative lines (GTA SA loading screen style) -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-vyra/20 to-transparent"></div>
    <div class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-sa-orange/20 to-transparent"></div>
    <div class="absolute -left-20 top-1/4 w-64 h-64 rounded-full bg-vyra/5 blur-3xl"></div>
    <div class="absolute -right-20 bottom-1/4 w-64 h-64 rounded-full bg-sa-orange/5 blur-3xl"></div>
  </div>

  <!-- Logo -->
  <div class="relative z-10 mb-6">
    <h1 class="font-display text-7xl sm:text-8xl md:text-9xl tracking-wider text-text leading-none">
      VYRA
    </h1>
    <p class="font-display text-2xl sm:text-3xl md:text-4xl tracking-widest text-vyra mt-1">
      NIGHT SHOP
    </p>
  </div>

  <!-- Tagline -->
  <p class="relative z-10 font-display text-lg sm:text-xl md:text-2xl text-sa-orange tracking-wide mt-4 max-w-xl">
    {siteConfig.tagline}
  </p>

  <!-- Subtitle -->
  <p class="relative z-10 text-text-muted text-sm sm:text-base mt-4 max-w-md leading-relaxed">
    Epicerie de nuit a {siteConfig.address.city} &mdash; Snacks, boissons, puff, CBD & produits importes
  </p>

  <!-- CTA -->
  <a
    href="#catalogue"
    class="relative z-10 mt-8 inline-flex items-center gap-2 px-8 py-3 min-h-[48px]
           bg-sa-orange text-bg font-bold text-base uppercase tracking-wide rounded-sm
           hover:bg-sa-orange-light hover:-translate-y-0.5 active:scale-[0.98]
           transition-all duration-150"
  >
    Decouvrir nos produits
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </a>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce-down" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-text-subtle" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</section>
