---
import { siteConfig } from "../data/site";
---

<section id="infos" class="py-16 sm:py-20 px-4 bg-surface cv-auto" aria-labelledby="heading-infos">
  <div class="max-w-6xl mx-auto">
    <div class="mb-10 reveal" style="--stagger: 0">
      <h2 id="heading-infos" class="font-display text-3xl sm:text-4xl md:text-5xl text-text">
        Infos pratiques
      </h2>
      <div class="mt-3 h-1 w-24 bg-gradient-to-r from-sa-violet to-sa-mauve rounded-sm" aria-hidden="true"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-8 md:gap-12">
      <!-- Info items -->
      <div class="space-y-6">
        <!-- Address -->
        <div class="flex gap-4 reveal" style="--stagger: 1">
          <div class="flex-shrink-0 w-10 h-10 rounded-sm bg-vyra-dim flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-vyra" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-text">Adresse</h3>
            <p class="text-text-muted mt-1">
              {siteConfig.address.street}<br />
              {siteConfig.address.postalCode} {siteConfig.address.city}
            </p>
          </div>
        </div>

        <!-- Hours -->
        <div class="flex gap-4 reveal" style="--stagger: 2">
          <div class="flex-shrink-0 w-10 h-10 rounded-sm bg-vyra-dim flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-vyra" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-text">Horaires</h3>
            <p class="text-text-muted mt-1">
              {siteConfig.hours.label}<br />
              <span class="font-mono text-vyra">{siteConfig.hours.open}</span> &mdash; <span class="font-mono text-vyra">{siteConfig.hours.close}</span>
            </p>
          </div>
        </div>

        <!-- Delivery -->
        <div class="flex gap-4 reveal" style="--stagger: 3">
          <div class="flex-shrink-0 w-10 h-10 rounded-sm bg-vyra-dim flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-vyra" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-text">Livraison</h3>
            <p class="text-text-muted mt-1">
              Livraison disponible sur Villers-Cotterêts et alentours
            </p>
          </div>
        </div>

        <!-- Phone -->
        <div class="flex gap-4 reveal" style="--stagger: 4">
          <div class="flex-shrink-0 w-10 h-10 rounded-sm bg-vyra-dim flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-vyra" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-text">Téléphone</h3>
            <a href={`tel:${siteConfig.phone}`} class="text-vyra hover:text-vyra-light transition-colors mt-1 block">
              {siteConfig.phoneDisplay}
            </a>
          </div>
        </div>
      </div>

      <!-- Map -->
      <div class="reveal rounded-sm overflow-hidden border border-surface-border h-[300px] md:h-full min-h-[300px]" style="--stagger: 2">
        <iframe
          title={`Carte de ${siteConfig.name} à ${siteConfig.address.city}`}
          src={`https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2590!2d${siteConfig.geo.longitude}!3d${siteConfig.geo.latitude}!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s${encodeURIComponent(siteConfig.address.street + ', ' + siteConfig.address.city)}!5e0!3m2!1sfr!2sfr`}
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </div>
</section>
